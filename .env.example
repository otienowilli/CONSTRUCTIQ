# CONSTRUCTIQ Environment Configuration

# Application
APP_NAME=CONSTRUCTIQ
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost

# Database
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=constructiq
DB_USERNAME=constructiq_user
DB_PASSWORD=constructiq_pass_2024

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# JWT Authentication
JWT_SECRET=your-secret-key-change-this-in-production
JWT_TTL=1440

# AI Engine
AI_ENGINE_URL=http://ai-engine:8001
OPENAI_API_KEY=your-openai-api-key-here

# AWS (for file storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

# Email
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@constructiq.com
MAIL_FROM_NAME="${APP_NAME}"

# IoT
MQTT_BROKER=iot-gateway
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Mobile App
MOBILE_APP_VERSION=1.0.0
FORCE_UPDATE=false

# Analytics
GOOGLE_ANALYTICS_ID=

